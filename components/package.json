{
  "name": "@opentrace/components",
  "version": "0.1.1",
  "type": "module",
  "description": "React components for graph visualization — powered by Sigma.js and Graphology",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentrace/opentrace",
    "directory": "components"
  },
  "main": "./dist/opentrace-components.cjs",
  "module": "./dist/opentrace-components.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/opentrace-components.js",
      "require": "./dist/opentrace-components.cjs"
    },
    "./utils": {
      "types": "./dist/src/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./indexing": {
      "types": "./dist/src/indexing/index.d.ts",
      "import": "./dist/indexing.js",
      "require": "./dist/indexing.cjs"
    },
    "./pipeline": {
      "types": "./dist/src/pipeline/index.d.ts",
      "import": "./dist/pipeline.js",
      "require": "./dist/pipeline.cjs"
    },
    "./pipeline/wasm": {
      "types": "./dist/src/pipeline/wasm.d.ts",
      "import": "./dist/pipeline-wasm.js",
      "require": "./dist/pipeline-wasm.cjs"
    },
    "./chat": {
      "types": "./dist/src/chat/index.d.ts",
      "import": "./dist/chat.js",
      "require": "./dist/chat.cjs"
    },
    "./style.css": "./dist/components.css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "opentrace-copy-wasm": "./bin/copy-wasm.js"
  },
  "files": [
    "dist",
    "public/wasm",
    "bin"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && tsc",
    "test": "vitest run",
    "fmt": "prettier --write .",
    "lint": "eslint . && prettier --check ."
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "mermaid": ">=11.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-markdown": ">=9.0.0",
    "remark-gfm": ">=4.0.0",
    "web-tree-sitter": ">=0.24.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "web-tree-sitter": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "react-markdown": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    }
  },
  "dependencies": {
    "@react-sigma/core": "^5.0.6",
    "@react-sigma/layout-forceatlas2": "^5.0.6",
    "@sigma/edge-curve": "^3.1.0",
    "d3-force": "^3.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-types": "^0.24.8",
    "react-window": "^2.2.7",
    "sigma": "^3.0.2"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.34",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^29.0.0",
    "mermaid": "^11.13.0",
    "prettier": "^3.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "web-tree-sitter": "^0.26.6"
  }
}

{
  "name": "@opentrace/opentrace",
  "version": "0.1.1",
  "type": "module",
  "description": "React components for graph visualization — powered by Pixi.js and Graphology",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentrace/opentrace",
    "directory": "ui"
  },
  "main": "./dist/lib/opentrace-components.cjs",
  "module": "./dist/lib/opentrace-components.js",
  "types": "./dist/lib/src/components/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/src/components/index.d.ts",
      "import": "./dist/lib/opentrace-components.js",
      "require": "./dist/lib/opentrace-components.cjs"
    },
    "./utils": {
      "types": "./dist/lib/src/components/utils.d.ts",
      "import": "./dist/lib/utils.js",
      "require": "./dist/lib/utils.cjs"
    },
    "./indexing": {
      "types": "./dist/lib/src/components/indexing/index.d.ts",
      "import": "./dist/lib/indexing.js",
      "require": "./dist/lib/indexing.cjs"
    },
    "./pipeline": {
      "types": "./dist/lib/src/components/pipeline/index.d.ts",
      "import": "./dist/lib/pipeline.js",
      "require": "./dist/lib/pipeline.cjs"
    },
    "./pipeline/wasm": {
      "types": "./dist/lib/src/components/pipeline/wasm.d.ts",
      "import": "./dist/lib/pipeline-wasm.js",
      "require": "./dist/lib/pipeline-wasm.cjs"
    },
    "./chat": {
      "types": "./dist/lib/src/components/chat/index.d.ts",
      "import": "./dist/lib/chat.js",
      "require": "./dist/lib/chat.cjs"
    },
    "./store": {
      "types": "./dist/lib/src/store/index.d.ts",
      "import": "./dist/lib/store.js",
      "require": "./dist/lib/store.cjs"
    },
    "./job": {
      "types": "./dist/lib/src/job/index.d.ts",
      "import": "./dist/lib/job.js",
      "require": "./dist/lib/job.cjs"
    },
    "./app-components": {
      "types": "./dist/lib/src/appComponents/index.d.ts",
      "import": "./dist/lib/app-components.js",
      "require": "./dist/lib/app-components.cjs"
    },
    "./app": {
      "types": "./dist/lib/src/OpenTraceApp.d.ts",
      "import": "./dist/lib/app.js",
      "require": "./dist/lib/app.cjs"
    },
    "./style.css": "./dist/lib/opentrace.css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "opentrace-copy-wasm": "./bin/copy-wasm.js"
  },
  "files": [
    "dist/lib",
    "public/wasm",
    "bin"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build -c vite.config.lib.ts && tsc -p tsconfig.lib.json && tsc -p tsconfig.lib-app.json",
    "build:wasm": "bash scripts/build-wasm.sh",
    "fmt": "prettier --write .",
    "lint": "eslint . && prettier --check .",
    "preview": "vite preview",
    "test": "vitest run",
    "validate-build": "node scripts/validate-build.mjs",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "web-tree-sitter": ">=0.24.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "web-tree-sitter": {
      "optional": true
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@ladybugdb/wasm-core": "0.15.2",
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.3.0",
    "apache-arrow": "^21.1.0",
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "fflate": "^0.8.2",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-types": "^0.24.8",
    "idb": "^8.0.3",
    "mermaid": "^11.6.0",
    "parquet-wasm": "^0.7.1",
    "pixi.js": "^8.17.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "remark-gfm": "^4.0.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "web-tree-sitter": ">=0.24.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-quadtree": "^3.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "ts-proto": "^2.11.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.8",
    "@playwright/test": "^1.52.0",
    "vitest": "^3.2.1"
  }
}

{
  "suite_name": "Python Project — Graph Accuracy",
  "description": "Validates indexing accuracy for a Python Flask app with SQLite database layer.",
  "fixture": "tests/fixtures/python/project",
  "repo_id": "test/py-project",
  "tasks": [
    {
      "id": "stats_has_nodes",
      "category": "structure",
      "description": "Graph should contain nodes after indexing",
      "tool": "get_stats",
      "tool_args": {},
      "assertions": [
        {"type": "has_key", "value": "total_nodes"},
        {"type": "key_gte", "key": "total_nodes", "value": 1}
      ]
    },
    {
      "id": "stats_has_edges",
      "category": "structure",
      "description": "Graph should contain relationships after indexing",
      "tool": "get_stats",
      "tool_args": {},
      "assertions": [
        {"type": "key_gte", "key": "total_edges", "value": 1}
      ]
    },
    {
      "id": "find_main_file",
      "category": "symbol_discovery",
      "description": "Search should find main.py",
      "tool": "search_graph",
      "tool_args": {"query": "main.py", "nodeTypes": "File"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "main.py"}
      ]
    },
    {
      "id": "find_db_file",
      "category": "symbol_discovery",
      "description": "Search should find db.py",
      "tool": "search_graph",
      "tool_args": {"query": "db.py", "nodeTypes": "File"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "db.py"}
      ]
    },
    {
      "id": "find_database_class",
      "category": "symbol_discovery",
      "description": "Search should find the Database class",
      "tool": "search_graph",
      "tool_args": {"query": "Database", "nodeTypes": "Class"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "Database"}
      ]
    },
    {
      "id": "list_all_files",
      "category": "structure",
      "description": "Project should have at least 2 Python files indexed",
      "tool": "list_nodes",
      "tool_args": {"type": "File"},
      "assertions": [
        {"type": "min_count", "value": 2},
        {"type": "result_contains_name", "value": "main.py"},
        {"type": "result_contains_name", "value": "db.py"}
      ]
    },
    {
      "id": "list_classes",
      "category": "structure",
      "description": "Should have the Database class",
      "tool": "list_nodes",
      "tool_args": {"type": "Class"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "Database"}
      ]
    },
    {
      "id": "list_functions",
      "category": "structure",
      "description": "Should have functions from both files",
      "tool": "list_nodes",
      "tool_args": {"type": "Function"},
      "assertions": [
        {"type": "min_count", "value": 2}
      ]
    },
    {
      "id": "find_list_users",
      "category": "symbol_discovery",
      "description": "Search should find the list_users function",
      "tool": "search_graph",
      "tool_args": {"query": "list_users", "nodeTypes": "Function"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "list_users"}
      ]
    },
    {
      "id": "find_create_user",
      "category": "symbol_discovery",
      "description": "Search should find the create_user function",
      "tool": "search_graph",
      "tool_args": {"query": "create_user", "nodeTypes": "Function"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "create_user"}
      ]
    },
    {
      "id": "find_initialize_method",
      "category": "symbol_discovery",
      "description": "Search should find the Database.initialize method",
      "tool": "search_graph",
      "tool_args": {"query": "initialize"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "initialize"}
      ]
    },
    {
      "id": "find_get_all_users",
      "category": "symbol_discovery",
      "description": "Search should find the get_all_users method",
      "tool": "search_graph",
      "tool_args": {"query": "get_all_users"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "get_all_users"}
      ]
    },
    {
      "id": "find_insert_user",
      "category": "symbol_discovery",
      "description": "Search should find the insert_user method",
      "tool": "search_graph",
      "tool_args": {"query": "insert_user"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "result_contains_name", "value": "insert_user"}
      ]
    },
    {
      "id": "search_type_filter",
      "category": "search_quality",
      "description": "Searching for 'main' with File filter should only return Files",
      "tool": "search_graph",
      "tool_args": {"query": "main", "nodeTypes": "File"},
      "assertions": [
        {"type": "min_count", "value": 1},
        {"type": "all_have_type", "value": "File"}
      ]
    },
    {
      "id": "search_no_results",
      "category": "search_quality",
      "description": "Searching for nonsense should return empty",
      "tool": "search_graph",
      "tool_args": {"query": "zzz_nonexistent_zzz"},
      "assertions": [
        {"type": "exact_count", "value": 0}
      ]
    },
    {
      "id": "has_repository_node",
      "category": "structure",
      "description": "Should have a Repository node",
      "tool": "list_nodes",
      "tool_args": {"type": "Repository"},
      "assertions": [
        {"type": "min_count", "value": 1}
      ]
    }
  ]
}
